// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Visi {
  id   String  @id @default(uuid())
  name String
  desc String?

  misi Misi[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Misi {
  id   String  @id @default(uuid())
  name String
  desc String?

  visiId String
  visi   Visi   @relation(fields: [visiId], references: [id])

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  renstraMisis RenstraMisi[]
}

model Renstra {
  id           String        @id @default(uuid())
  name         String
  desc         String?
  startDate    DateTime
  endDate      DateTime
  unitId       String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  renstraMisis RenstraMisi[]
  tujuans      Tujuan[]
  rkts         Rkt[]
}

model RenstraMisi {
  id        String @id @default(uuid())
  renstraId String
  misiId    String

  renstra Renstra @relation(fields: [renstraId], references: [id])
  misi    Misi    @relation(fields: [misiId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Indicator {
  id     String @id @default(uuid())
  name   String
  target String
  satuan String

  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  tujuanIndicators      TujuanIndicator[]
  programIndicators     ProgramIndicator[]
  kegiatanIndicators    KegiatanIndicator[]
  subKegiatanIndicators SubKegiatanIndicator[]
  rktInputIndicators    RktInputIndicator[]
  rktOutputIndicators   RktOutputIndicator[]
  rktOutcomeIndicators  RktOutcomeIndicator[]
}

model Tujuan {
  id        String  @id @default(uuid())
  name      String
  unitId    String
  renstraId String
  renstra   Renstra @relation(fields: [renstraId], references: [id])

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  tujuanIndicators TujuanIndicator[]
  programs         Program[]
}

model Program {
  id            String @id @default(uuid())
  name          String
  unitId        String
  totalAnggaran Float
  tujuanId      String
  tujuan        Tujuan @relation(fields: [tujuanId], references: [id])

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  programIndicators ProgramIndicator[]
  kegiatans         Kegiatan[]
}

model Kegiatan {
  id            String  @id @default(uuid())
  name          String
  unitId        String
  totalAnggaran Float
  programId     String
  program       Program @relation(fields: [programId], references: [id])

  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  kegiatanIndicators KegiatanIndicator[]
  subKegiatans       SubKegiatan[]
}

model SubKegiatan {
  id            String   @id @default(uuid())
  name          String
  unitId        String
  totalAnggaran Float
  kegiatanId    String
  kegiatan      Kegiatan @relation(fields: [kegiatanId], references: [id])

  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  subKegiatanIndicators SubKegiatanIndicator[]
  rktSubKegiatans       RktSubKegiatan[]
}

model TujuanIndicator {
  id          String @id @default(uuid())
  tujuanId    String
  indicatorId String

  tujuan    Tujuan    @relation(fields: [tujuanId], references: [id])
  indicator Indicator @relation(fields: [indicatorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProgramIndicator {
  id          String @id @default(uuid())
  programId   String
  indicatorId String

  program   Program   @relation(fields: [programId], references: [id])
  indicator Indicator @relation(fields: [indicatorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model KegiatanIndicator {
  id          String @id @default(uuid())
  kegiatanId  String
  indicatorId String

  kegiatan  Kegiatan  @relation(fields: [kegiatanId], references: [id])
  indicator Indicator @relation(fields: [indicatorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SubKegiatanIndicator {
  id            String @id @default(uuid())
  subKegiatanId String
  indicatorId   String

  subKegiatan SubKegiatan @relation(fields: [subKegiatanId], references: [id])
  indicator   Indicator   @relation(fields: [indicatorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Rkt {
  id              String           @id @default(uuid())
  name            String
  unitId          String
  totalAnggaran   Float
  renstraId       String
  renstra         Renstra          @relation(fields: [renstraId], references: [id])
  rktSubKegiatans RktSubKegiatan[]

  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  rktInputIndicators   RktInputIndicator[]
  rktOutputIndicators  RktOutputIndicator[]
  rktOutcomeIndicators RktOutcomeIndicator[]
}

model RktSubKegiatan {
  id            String      @id @default(uuid())
  subKegiatanId String
  subKegiatan   SubKegiatan @relation(fields: [subKegiatanId], references: [id])
  rktId         String
  rkt           Rkt         @relation(fields: [rktId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RktInputIndicator {
  id          String @id @default(uuid())
  rktId       String
  indicatorId String

  rkt       Rkt       @relation(fields: [rktId], references: [id])
  indicator Indicator @relation(fields: [indicatorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RktOutputIndicator {
  id          String @id @default(uuid())
  rktId       String
  indicatorId String

  rkt       Rkt       @relation(fields: [rktId], references: [id])
  indicator Indicator @relation(fields: [indicatorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RktOutcomeIndicator {
  id          String @id @default(uuid())
  rktId       String
  indicatorId String

  rkt       Rkt       @relation(fields: [rktId], references: [id])
  indicator Indicator @relation(fields: [indicatorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Umpeg {
  id       String @id @default(uuid())
  name     String
  unitId   String
  nip      String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Jpt {
  id       String @id @default(uuid())
  name     String
  unitId   String
  nip      String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}