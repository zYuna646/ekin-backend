# Staging Environment
# Copy this to .env.staging and fill in your values

NODE_ENV=production

# Domain
API_DOMAIN=api.staging.swissleft.com

# Database
DB_NAME=swissleft_staging
DB_USER=swissleft_user
DB_PASSWORD=your_secure_password_here

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# JWT Secret
JWT_SECRET=your_jwt_secret_key_change_me

# Application
PORT=3000
APP_URL=https://api.staging.swissleft.com

# I18n
I18N_FALLBACK_LANGUAGE=en

# File Upload
UPLOAD_MAX_FILE_SIZE=10485760

# Traefik/SSL
ACME_EMAIL=admin@swissleft.com
